DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=false
# Include localhost for internal Docker health checks
DJANGO_ALLOWED_HOSTS=center.larp.co.il,localhost
APP_BASE_URL=https://center.larp.co.il
CSRF_TRUSTED_ORIGINS=https://center.larp.co.il

# Use private connection URI when deployed on DO VPC (fra1)
DATABASE_URL=postgresql://center_larp:replace-me@private-db-postgresql-fra1-01-do-user-840119-0.f.db.ondigitalocean.com:25060/center_larp?sslmode=require

# Resend SMTP relay (https://resend.com)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_REPLACE_ME_WITH_RESEND_API_KEY
DEFAULT_FROM_EMAIL="Center LARP <noreply@larp.co.il>"

# Auto-created admin superuser (created on container startup if missing)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=replace-me-with-a-secure-password
DJANGO_SUPERUSER_EMAIL=replace-me@example.com

CARDCOM_TERMINAL_NUMBER=replace-me
CARDCOM_API_NAME=replace-me
CARDCOM_API_PASSWORD=replace-me
CARDCOM_LOW_PROFILE_URL=https://secure.cardcom.solutions/api/v11/LowProfile/Create
CARDCOM_GET_LP_RESULT_URL=https://secure.cardcom.solutions/api/v11/LowProfile/GetLpResult

MORNING_ENV=production
MORNING_API_KEY_ID=replace-me
MORNING_API_SECRET=replace-me
MORNING_BASE_URL=replace-with-live-value-from-current-docs
